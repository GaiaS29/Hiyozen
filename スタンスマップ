function SelectedCountryDetail({ code }: { code: string }) {
	const country = COUNTRIES.find((c) => c.code === code);
	if (!country) return null;

	return (
		<Card>
			<CardHeader trailing={<Pill tone="info">{country.region}</Pill>}>
				{country.name}（{country.code}）
			</CardHeader>
			<CardBody>
				<Stack gap={8}>
					<Text size="small" tone="secondary">
						主要ブロック：{country.block}
					</Text>
					<Table
						headers={["論点", "スタンス"]}
						rows={[
							["論点1（普遍的人権 vs 政策目標）", country.labels["1"]],
							["論点2a（発展の権利）", country.labels["2a"]],
							["論点2b（文化・宗教）", country.labels["2b"]],
							["論点3（コンディショナリティ）", country.labels["3"]],
						]}
						framed={false}
					/>
				</Stack>
			</CardBody>
		</Card>
	);
}

