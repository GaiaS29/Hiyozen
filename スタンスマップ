const PLOT = {
	left: 100,
	top: 48,
	width: 520,
	height: 420,
};

const PLOT_RIGHT = PLOT.left + PLOT.width;
const PLOT_BOTTOM = PLOT.top + PLOT.height;
const CX = PLOT.left + PLOT.width / 2;
const CY = PLOT.top + PLOT.height / 2;

type RegionStyle = { fill: string; stroke: string };

type CategoryColors = {
	gray: string;
	purple: string;
	green: string;
	yellow: string;
	cyan: string;
	pink: string;
	blue: string;
	orange: string;
};

function regionStyle(region: string, category: CategoryColors): RegionStyle {
	switch (region) {
		case "非洲":
			return { fill: category.yellow, stroke: category.orange };
		case "アジア":
			return { fill: category.green, stroke: category.yellow };
		case "南米":
			return { fill: category.green, stroke: category.cyan };
		case "中美":
			return { fill: category.yellow, stroke: category.green };
		case "欧州":
			return { fill: category.cyan, stroke: category.purple };
		default:
			return { fill: category.gray, stroke: category.gray };
	}
}

function hashOffset(name: string): { dx: number; dy: number } {
	let h = 0;
	for (let i = 0; i < name.length; i += 1) {
		h = (h * 31 + name.charCodeAt(i)) % 997;
	}
	return {
		dx: ((h % 17) - 8) * 1.4,
		dy: (((h / 17) | 0) % 17 - 8) * 1.4,
	};
}

function computePoint(c: CountryPoint) {
	const xRaw = c.stances["1"] === 2 ? 18 : 82;
	const yRaw = ((c.stances["2a"] - 1) / 2) * 100;
	const { dx, dy } = hashOffset(c.name);
	const x = Math.min(94, Math.max(6, xRaw + dx));
	const y = Math.min(94, Math.max(6, yRaw + dy));
	return {
		x: PLOT.left + (x / 100) * PLOT.width,
		y: PLOT.top + (y / 100) * PLOT.height,
		xPct: x,
		yPct: y,
	};
}

